# Copy to .env.local and fill in. Every value is OPTIONAL — with none set the app
# runs in a fully-working deterministic mock mode (no AI, no persistence).

# --- Claude agent backend (real task/deliverable generation) ---
# Official Anthropic API:
ANTHROPIC_API_KEY=
# ...or an Anthropic-compatible proxy (e.g. claudeopus.pro). When using a proxy,
# set the base URL + bearer token instead of ANTHROPIC_API_KEY:
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
# Optional model override (default: claude-opus-4-7):
ANTHROPIC_MODEL=
#
# IMPORTANT: if your shell already exports ANTHROPIC_BASE_URL / ANTHROPIC_AUTH_TOKEN
# (common with the Claude Code CLI), Next.js will NOT let the plain vars above
# override them. Use these HELM_-prefixed vars instead — they always take
# precedence over .env.local-vs-shell collisions:
#   HELM_ANTHROPIC_BASE_URL=https://api.claudeopus.pro
#   HELM_ANTHROPIC_AUTH_TOKEN=sk-ant-co-...
#   HELM_ANTHROPIC_MODEL=claude-opus-4-8
HELM_ANTHROPIC_BASE_URL=
HELM_ANTHROPIC_AUTH_TOKEN=
HELM_ANTHROPIC_MODEL=

# --- Persistence (Supabase Postgres via PostgREST) ---
# Set BOTH to enable companies/tasks/artifacts to persist across refreshes.
SUPABASE_URL=
SUPABASE_KEY=

# --- Write authorization (recommended in production) ---
# When set, every write (creating tasks in an existing workspace, executing a
# task, patching a task) must present that workspace's capability token, derived
# server-side as HMAC-SHA256(APP_SECRET, workspaceId). Leave empty for the open
# local demo. Use a long, random value in production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=

# --- Scheduled runs (cron) ---
# /api/cron drains one actionable task per active workspace each tick, so
# companies keep advancing with no tab open. vercel.json schedules it; set this
# to a long random value and Vercel will send it as a Bearer token (requests
# without it are rejected). Leave empty to allow unauthenticated local testing.
CRON_SECRET=

# --- Live skill discovery (agents search the skill ecosystem per task) ---
# GitHub works with NO key (60 req/hr). Add a token to raise the limit. Add a
# skills.sh key (sk_live_...) to upgrade discovery to skills.sh semantic search.
GITHUB_TOKEN=
SKILLS_SH_API_KEY=
